# ============================================
# API PERSONNEL
# ============================================
VITE_PERSONNEL_API_URL=https://api.ivos.com

# ============================================
# EMAIL CENTER
# ============================================
VITE_EMAIL_CENTER_BACKEND_URL=http://localhost:8787
VITE_EMAIL_CENTER_ADMIN_TOKEN=

# Backend API (used by `npm run email-center:api`)
EMAIL_CENTER_API_PORT=8787
EMAIL_CENTER_FRONTEND_URL=http://localhost:3000
EMAIL_CENTER_CORS_ORIGIN=http://localhost:3000
EMAIL_CENTER_ADMIN_TOKEN=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_WEBHOOK_SECRET=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_TENANT_ID=common
OUTLOOK_WEBHOOK_SECRET=
OUTLOOK_WEBHOOK_CLIENT_STATE=
EMAIL_CENTER_WEBHOOK_SHARED_SECRET=

# ============================================
# VARIABLES D'ENVIRONNEMENT - IVOS
# ============================================

# Copiez ce fichier en .env.local et remplissez les valeurs

# ============================================
# SUPABASE
# ============================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# N8N WEBHOOKS
# ============================================
VITE_N8N_WEBHOOK_BASE_URL=https://your-n8n-instance.com
VITE_N8N_PDF_GENERATION_WEBHOOK=/webhook/generate-pdf
VITE_N8N_NOTIFICATION_WEBHOOK=/webhook/send-notification

# ============================================
# CONFIGURATION APPLICATION
# ============================================
VITE_APP_NAME=IVOS Fleet Management
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# ============================================
# SENTRY MONITORING (Optionnel)
# ============================================
# DSN Sentry pour le tracking d'erreurs et performance
# Laisser vide pour désactiver Sentry
VITE_SENTRY_DSN=

# ============================================
# FEATURE FLAGS
# ============================================
VITE_DEMO_MODE=false
VITE_DEBUG=false
VITE_OFFLINE_MODE=false

# Adresse par défaut pour les missions (modifiable)
VITE_MISSION_ADDRESS=THIES, Mbour, KIGNABOUR

# ============================================
# GOOGLE MAPS (optionnel pour géolocalisation)
# ============================================
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-key

# ============================================
# SENTRY (optionnel pour error tracking)
# ============================================
VITE_SENTRY_DSN=your-sentry-dsn

# ============================================
# ⚠️  SECURITY - BACKUP & AUTHENTICATION
# ============================================
# WARNING: These credentials are visible in the browser bundle!
# For production, use a backend service with Supabase Auth instead.
# CHANGE these values for each environment!
VITE_BACKUP_ADMIN_PASSWORD=CHANGE-THIS-PASSWORD-IN-PRODUCTION
VITE_AUTH_DEMO_PASSWORD=demo123456
